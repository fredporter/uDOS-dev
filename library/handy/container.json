{
  "$schema": "../container.schema.json",
  "container": {
    "id": "handy",
    "name": "Handy STT",
    "description": "Free, open source speech-to-text application. Completely offline using Whisper or Parakeet models.",
    "type": "git",
    "source": "https://github.com/cjpais/Handy",
    "ref": "main",
    "cloned_at": null,
    "last_update": null,
    "commit": null,
    "version": "0.6.10"
  },
  "policy": {
    "read_only": true,
    "auto_update": false,
    "update_channel": "wizard_only",
    "verify_signatures": false
  },
  "integration": {
    "wrapper_path": "extensions/voice/handy/",
    "service_path": "wizard/services/voice_service.py",
    "handler_path": "core/commands/voice_handler.py",
    "install_script": "wizard/tools/voice_setup.py"
  },
  "metadata": {
    "license": "MIT",
    "homepage": "https://handy.computer/",
    "documentation": "https://github.com/cjpais/Handy#readme",
    "maintainer": "CJ Pais / uDOS Wizard Server",
    "discord": "https://discord.com/invite/WVBeWsNXK4"
  },
  "capabilities": {
    "direction": "speech-to-text",
    "offline": true,
    "languages": "auto-detect",
    "vad": "Silero Voice Activity Detection",
    "models": {
      "whisper": {
        "small": {"size": "487MB", "url": "https://blob.handy.computer/ggml-small.bin"},
        "medium": {"size": "492MB", "url": "https://blob.handy.computer/whisper-medium-q4_1.bin"},
        "turbo": {"size": "1600MB", "url": "https://blob.handy.computer/ggml-large-v3-turbo.bin"},
        "large": {"size": "1100MB", "url": "https://blob.handy.computer/ggml-large-v3-q5_0.bin"}
      },
      "parakeet": {
        "v2": {"size": "473MB", "url": "https://blob.handy.computer/parakeet-v2-int8.tar.gz"},
        "v3": {"size": "478MB", "url": "https://blob.handy.computer/parakeet-v3-int8.tar.gz"}
      }
    }
  },
  "system_requirements": {
    "whisper_models": {
      "macos": "M series Mac or Intel",
      "windows": "Intel, AMD, or NVIDIA GPU",
      "linux": "Intel, AMD, or NVIDIA GPU"
    },
    "parakeet_models": {
      "cpu_only": true,
      "minimum": "Intel Skylake (6th gen) or equivalent AMD",
      "speed": "~5x real-time on mid-range hardware"
    },
    "platforms": ["linux", "macos", "windows"]
  },
  "wizard_commands": [
    "VOICE LISTEN",
    "VOICE LISTEN -t 30",
    "VOICE TRANSCRIBE <file.wav>",
    "VOICE MODEL whisper-small",
    "VOICE DOWNLOAD parakeet-v3"
  ],
  "cli_version": {
    "repo": "https://github.com/cjpais/handy-cli",
    "note": "Original Python CLI version for headless servers"
  }
}
