{
{\n  "$schema": "../../container.schema.json",
  "container": {
    "id": "gtx-form",
    "name": "GTX Form",
    "description": "Typeform-style form builder with React and Vite",
    "type": "git",
    "source": "https://github.com/gtx-form/gtx-form",
    "ref": "main",
    "cloned_at": null,
    "last_update": null,
    "commit": null,
    "version": null
  },
  "policy": {
    "read_only": true,
    "auto_update": false,
    "update_channel": "wizard_only",
    "verify_signatures": false
  },
  "integration": {
    "wrapper_path": "extensions/forms/gtx/",
    "handler_path": "core/commands/form_handler.py",
    "install_script": null
  },
  "build": {
    "type": "npm",
    "build_command": "npm install && npm run build",
    "runtime": "browser",
    "static_output": "dist/"
  },
  "metadata": {
    "license": "MIT",
    "homepage": "https://github.com/gtx-form/gtx-form",
    "documentation": "library/gtx-form/README.md",
    "maintainer": "Community / uDOS Wizard Server",
    "category": "forms"
  }
}
