{
  "$schema": "../container.schema.json",
  "container": {
    "id": "piper",
    "name": "Piper TTS",
    "description": "Fast, local neural text-to-speech system. Supports 30+ languages with natural-sounding voices.",
    "type": "git",
    "source": "https://github.com/OHF-Voice/piper1-gpl",
    "ref": "main",
    "cloned_at": null,
    "last_update": null,
    "commit": null,
    "version": null
  },
  "policy": {
    "read_only": true,
    "auto_update": false,
    "update_channel": "wizard_only",
    "verify_signatures": false
  },
  "integration": {
    "wrapper_path": "extensions/voice/piper/",
    "service_path": "wizard/services/voice_service.py",
    "handler_path": "core/commands/voice_handler.py",
    "install_script": "wizard/tools/voice_setup.py"
  },
  "metadata": {
    "license": "GPL-3.0",
    "license_note": "Original rhasspy/piper was MIT, new OHF-Voice fork is GPL-3.0",
    "homepage": "https://rhasspy.github.io/piper-samples/",
    "documentation": "https://github.com/OHF-Voice/piper1-gpl#readme",
    "maintainer": "OHF Voice / uDOS Wizard Server",
    "original_repo": "https://github.com/rhasspy/piper",
    "archived": false
  },
  "capabilities": {
    "direction": "text-to-speech",
    "offline": true,
    "languages": ["en", "de", "fr", "es", "it", "pt", "pl", "nl", "ru", "uk", "zh", "ja", "ko", "vi", "th", "ar", "el", "fi", "sv", "da", "no", "hu", "cs", "sk", "ro", "bg", "hr", "sl", "sr", "mk", "ca", "is", "sw"],
    "models": {
      "source": "https://huggingface.co/rhasspy/piper-voices",
      "format": "onnx",
      "sizes": ["tiny", "small", "medium", "large"]
    }
  },
  "system_requirements": {
    "cpu": "Any modern CPU (x64, ARM64)",
    "gpu": "Optional - ONNX Runtime GPU acceleration",
    "memory": "256MB - 2GB depending on model size",
    "platforms": ["linux", "macos", "windows"]
  },
  "wizard_commands": [
    "VOICE SAY <text>",
    "VOICE MODEL <name>",
    "VOICE VOICES",
    "VOICE DOWNLOAD <model>"
  ]
}
